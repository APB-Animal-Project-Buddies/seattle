NHOST_SUBDOMAIN=your-subdomain
NHOST_REGION=us-west-2
NHOST_GRAPHQL_SECRET="your-hasura-admin-secret"  # Quote if contains special chars like # or @

# Client-side Nhost Auth SDK (browser). Must be NEXT_PUBLIC_* to reach the client.
# Values are the same subdomain/region as above. If these two are omitted, the
# client falls back to parsing NEXT_PUBLIC_NHOST_GRAPHQL_URL.
NEXT_PUBLIC_NHOST_SUBDOMAIN=your-subdomain
NEXT_PUBLIC_NHOST_REGION=us-west-2
NEXT_PUBLIC_NHOST_GRAPHQL_URL=https://your-subdomain.hasura.us-west-2.nhost.run/v1/graphql

# Constructed URLs (for reference)
NHOST_GRAPHQL_URL=https://your-subdomain.hasura.us-west-2.nhost.run/v1/graphql
NHOST_AUTH_URL=https://your-subdomain.auth.us-west-2.nhost.run/v1
NHOST_STORAGE_URL=https://your-subdomain.storage.us-west-2.nhost.run/v1
NHOST_FUNCTIONS_URL=https://your-subdomain.functions.us-west-2.nhost.run/v1

# Discord Bot
DISCORD_TOKEN=your-discord-bot-token
DISCORD_CLIENT_ID=your-discord-client-id

# Ideas Sync
IDEAS_SYNC_API_KEY=your-ideas-sync-api-key

# Gemini (for AI recipe image generation)
# Get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key
# Optional override (default is "gemini-2.5-flash-image")
# GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# Anthropic (recipe upload -> form extraction, POST /api/dishes/parse)
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key
# Optional model override (default is "claude-haiku-4-5")
# RECIPE_EXTRACT_MODEL=claude-haiku-4-5
